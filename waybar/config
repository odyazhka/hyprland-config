[
  {
    "layer": "top",
    "position": "top",
    "height": 24,

    "modules-left": [
      "custom/launcher",
      "hyprland/window",
      "custom/texttwo",
      "custom/textthree",
      "custom/textfour",
      "custom/textfive",
    ],
    "modules-center": [
      "sway/window",
      "custom/cava"
    ],
    "modules-right": [
      "hyprland/language",
      "custom/wifi",
      "custom/ping",
      "custom/bluetooth",
      "cpu",
      "memory",
      "pulseaudio",
      "backlight",
      "keyboard-state",
      "battery",
      "battery#bat2",
      "tray",
      "clock"
    ],
    "hyprland/window": {
      "format": "{class}",
      "max-length": 20,
      "rewrite": {
        "^(?!.*\\S).*": " "
      }
    },
    "custom/launcher": {
      "format": "\udb82\udcc7 ",
      "on-click": "wofi --show drun --width 33% --height 50% --location 1",
      "tooltip": false
    },
    "keyboard-state": {
      "numlock": true,
      "capslock": true,
      "format": "{name} {icon}",
      "format-icons": {
        "locked": "пА£",
        "unlocked": "пВЬ"
      }
    },
    "sway/mode": {
      "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
      "format": "{icon} {count}",
      "show-empty": false,
      "format-icons": [
        "",
        "пЛТ"
      ],
      "tooltip": true,
      "tooltip-format": "{app}: {title}"
    },
    "mpd": {
      "format": "пАБ  {title} - {artist} {stateIcon} [{elapsedTime:%M:%S}/{totalTime:%M:%S}] {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}[{songPosition}/{queueLength}] [{volume}%]",
      "format-disconnected": "пАБ Disconnected",
      "format-stopped": "пАБ {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped",
      "unknown-tag": "N/A",
      "interval": 2,
      "consume-icons": {
        "on": "пГД "
      },
      "random-icons": {
        "on": "пБі "
      },
      "repeat-icons": {
        "on": "пАЮ "
      },
      "single-icons": {
        "on": "пАЮ1 "
      },
      "state-icons": {
        "paused": "пБМ",
        "playing": "пБЛ"
      },
      "tooltip-format": "MPD (connected)",
      "tooltip-format-disconnected": "MPD (disconnected)",
      "on-click": "mpc toggle",
      "on-click-right": "foot -a ncmpcpp ncmpcpp",
      "on-scroll-up": "mpc volume +2",
      "on-scroll-down": "mpc volume -2"
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "пБЃ ",
        "deactivated": "пБ∞ "
      }
    },
    "tray": {
    },
    "clock": {
    	"interval": 60,
    	"format":"{:%d.%m.%Y  %H:%M }",
    },
    "cpu": {
      "format": "пЛЫ  {usage}% "
    },
    "memory": {
      "format": "пГЙ {}% "
    },
    "backlight": {
      "format": "{icon} {percent}%",
      "format-icons": [
        "оОН",
        "оПУ",
        "оПС",
        "оПП",
        "оПО",
        "оПН",
        "оПК",
        "оПИ",
        "оОЫ"
      ]
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-charging": "пЧІ {capacity}%",
      "format-plugged": "пЗ¶ {capacity}%",
      "format-alt": "{icon} {time}",
      "format-icons": [
        "пЙД ",
        "пЙГ ",
        "пЙВ ",
        "пЙБ ",
        "пЙА "
      ]
    },
    "battery#bat2": {
      "bat": "BAT2"
    },
    "network": {
      "format-wifi": "{essid} ({signalStrength}%) пЗЂ",
      "format-ethernet": "пЮЦ {ifname}",
      "tooltip-format": "пЮЦ {ifname} via {gwaddr}",
      "format-linked": "пЮЦ {ifname} (No IP)",
      "format-disconnected": "Disconnected вЪ† {ifname}",
      "format-alt": "пЮЦ {ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
      "scroll-step": 5,
      "format": "{icon}  {volume}% {format_source} ",
      "format-bluetooth": "пКФ {icon} {volume}% {format_source}",
      "format-bluetooth-muted": "пЪ© пКФ {icon} {format_source}",
      "format-muted": "пЪ©  {format_source}",
      "format-source": "пД∞ {volume}% ",
      "format-source-muted": "пД±  ",
      "format-icons": {
        "default": [
          "вЬХ",
          "вЦБ",
          "вЦВ",
          "вЦГ",
          "вЦД",
          "вЦЕ",
          "вЦЖ",
          "вЦЗ",
          "вЦИ"
        ]
      },
      "on-click": "pavucontrol",
      "on-click-right": "foot -a pw-top pw-top"
    },
    "hyprland/language": {
        "format": "{}",
    	"format-en": "EN ",
    	"format-ru": "–†–£–° ",
    	"on-click": "hyprctl switchxkblayout all next"
	},
    "custom/wifi": {
      "format": "{}",
      "interval": 30,
      "exec": "status=$(nmcli radio wifi); connectivity=$(nmcli -t -f CONNECTIVITY g); if [ \"$status\" = \"disabled\" ]; then echo '<span color=\"#ff0000\">пЗЂвЬХ </span>'; elif [ \"$connectivity\" != \"full\" ]; then echo '<span color=\"#ff6000\">пЗЂ   ! </span>'; else echo '<span color=\"#ffffff\">пЗЂ </span>'; fi",
      "on-click": "kitty --class nmtui nmtui",
      "tooltip": false
    },
    "custom/ping": {
      "interval": 5,
      "exec": "ping -c 1 -W 2 8.8.8.8 | awk -F'[=/]' 'END{ if (NR==0 || $5 > 1000) print \"<span color=\\\"#ff0000\\\">у∞ЦЯвЬХ</span>\"; else print \"<span color=\\\"#ffffff\\\">у∞ЦЯ </span>\" }'",
      "format": "{}",
      "tooltip-format": "–Я—А–Њ–≤–µ—А–Ї–∞ —Б–≤—П–Ј–Є",
      "on-click": "kitty gping google.com" // –Х—Б–ї–Є —Г—Б—В–∞–љ–Њ–≤–ї–µ–љ gping вАФ –±—Г–і–µ—В –Ї—А–∞—Б–Є–≤—Л–є –≥—А–∞—Д–Є–Ї –њ—А–Є –Ї–ї–Є–Ї–µ
    },
    "custom/bluetooth": {
      "interval": 2,
      "exec": "cat /sys/class/rfkill/rfkill*/state | sed -n '2p' | grep -q '1' && echo '<span color=\"#bababa\">у∞Вѓ</span>' || echo '<span color=\"#bababa\">у∞В≤</span>'",
      "on-click": "blueman-manager",
      "tooltip-format": "–£–њ—А–∞–≤–ї–µ–љ–Є–µ Bluetooth"
    },
    "custom/cava": {
      "exec": "cava -p ~/.config/cava/config_waybar | sed -u 's/0/  /g; s/1/вЦВвЦВ/g; s/2/вЦГвЦГ/g; s/3/вЦДвЦД/g; s/4/вЦЕвЦЕ/g; s/5/вЦЖвЦЖ/g; s/6/вЦЗвЦЗ/g; s/7/вЦИвЦИ/g'",
      "format": "{}"
    }
},
  {
    "layer": "top",
    "position": "bottom",
    "height": 41,
    "width": 2,
    "modules-left": [
      "custom/os_button"
    ],
    "modules-center": [
      "sway/mode",
      "wlr/taskbar"
    ],
    "margin": "4",
    "sway/window": {
      "max-length": 50
    },
    "custom/os_button": {
      "format": "\udb82\udcc7",
      "on-click": "wofi --show drun --width 33% --height 50% --location bottom",
      "tooltip": false
    },
    "wlr/taskbar": {
      "format": "{icon}",
      "icon-size": 36,
      "on-click-middle": "close",
      "tooltip-format": "{title}",
      "ignore-list": [],
      "on-click": "activate"

    },
  }
]
